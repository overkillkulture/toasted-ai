#!/bin/bash
# TOASTED AI - Quick Command Interface
# Provides terminal commands for system control

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Function to run the Python daemon in background and send commands
toasted_daemon() {
    python3 /home/workspace/MaatAI/system_daemon.py "$@"
}

# Show usage
usage() {
    echo -e "${CYAN}TOASTED AI - System Monitor & Control${NC}"
    echo "======================================"
    echo ""
    echo "Usage: toasted <command> [options]"
    echo ""
    echo "Commands:"
    echo "  status           Show full system status"
    echo "  show_output      Toggle internal output display"
    echo "  show_output on  Turn output display ON"
    echo "  show_output off Turn output display OFF"
    echo "  qpu              Show QPU status"
    echo "  qpu acknowledge  Acknowledge QPU connection"
    echo "  maat             Show Ma'at balancing status"
    echo "  maat enable      Enable Ma'at balancing"
    echo "  maat disable     Disable Ma'at balancing"
    echo "  self_build       Show self-building process status"
    echo "  self_build start Start self-building process"
    echo "  self_build stop  Stop self-building process"
    echo "  decisions        Show recent decisions"
    echo "  boot             Run boot sequence"
    echo "  ratify           Run knowledge ratification"
    echo "  ratify:status   Show ratification status"
    echo "  ratify:report   Show ratification report"
    echo "  ratify:quarantine Show documents needing verification"
    echo "  help             Show this help"
    echo ""
    echo "Examples:"
    echo "  toasted status"
    echo "  toasted show_output on"
    echo "  toasted qpu acknowledge"
    echo "  toasted decisions 20"
}

# Parse command
case "${1:-help}" in
    status)
        echo -e "${GREEN}Running status check...${NC}"
        python3 -c "
import sys
sys.path.insert(0, '/home/workspace/MaatAI')
from system_daemon import cmd_status
print(cmd_status([]))
"
        ;;
    show_output)
        python3 -c "
import sys
sys.path.insert(0, '/home/workspace/MaatAI')
from system_daemon import cmd_show_output
print(cmd_show_output(['${2:-}']))
"
        ;;
    qpu)
        python3 -c "
import sys
sys.path.insert(0, '/home/workspace/MaatAI')
from system_daemon import cmd_qpu
print(cmd_qpu(['${2:-status}']))
"
        ;;
    maat)
        python3 -c "
import sys
sys.path.insert(0, '/home/workspace/MaatAI')
from system_daemon import cmd_maat
print(cmd_maat(['${2:-}']))
"
        ;;
    self_build)
        python3 -c "
import sys
sys.path.insert(0, '/home/workspace/MaatAI')
from system_daemon import cmd_self_build
print(cmd_self_build(['${2:-}']))
"
        ;;
    decisions)
        python3 -c "
import sys
sys.path.insert(0, '/home/workspace/MaatAI')
from system_daemon import cmd_decisions
print(cmd_decisions(['${2:-}']))
"
        ;;
    boot)
        echo -e "${YELLOW}Running boot sequence...${NC}"
        python3 /home/workspace/MaatAI/system_daemon.py --boot
        ;;
    ratify*)
        /home/workspace/MaatAI/toasted_ratify "$@"
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        usage
        ;;
esac
